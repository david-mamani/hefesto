# Copy to .env.local and fill in — see README "Local setup".
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
APP_SECRET=
COGNEE_API_KEY=
COGNEE_BASE_URL=https://api.cognee.ai/api/v1
GROQ_API_KEY=
ISOLATION_PATTERN=p1

# Telegram bot (one bot for the whole app)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Optional — the bot discovers its own username via getMe when unset
TELEGRAM_BOT_USERNAME=
# Optional — defaults to https://hefesto.org/api/telegram
TELEGRAM_WEBHOOK_URL=
